local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local BlockAnimID = "rbxassetid://18644623937"

local AnimationObject = Instance.new("Animation")
AnimationObject.AnimationId = BlockAnimID

local function IniciarDefesaInfinita(char)
    if not char then return end
    local humanoid = char:WaitForChild("Humanoid", 5)
    local animator = humanoid and humanoid:WaitForChild("Animator", 5)
    
    if animator then
        local blockTrack = animator:LoadAnimation(AnimationObject)
        blockTrack.Priority = Enum.AnimationPriority.Action4
        blockTrack.Looped = true
        
        blockTrack:Play()
        blockTrack:AdjustSpeed(0.001) 
        
        blockTrack.Stopped:Connect(function()
            task.wait()
            if char and char.Parent then
                blockTrack:Play()
                blockTrack:AdjustSpeed(0.001)
            end
        end)
    end
end

if LocalPlayer.Character then 
    task.spawn(IniciarDefesaInfinita, LocalPlayer.Character) 
end

LocalPlayer.CharacterAdded:Connect(function(char)
    task.spawn(IniciarDefesaInfinita, char)
end)
